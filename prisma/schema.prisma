// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  user_id                Int         @id @default(autoincrement())
  email                  String      @unique
  password_hash          String
  full_name              String?
  username               String?     @unique
  profile_picture        String?
  phone                  String?
  date_of_birth          DateTime?   @db.Date
  fitness_level          Int?
  preferred_difficulty   String?
  preferred_max_duration Int?
  location_country       String?
  location_city          String?
  bio                    String?     @db.Text
  otp                    String?
  otp_expires            DateTime?
  trek_images            TrekImage[]

  @@map("users")
}

model Trek {
  trek_id                           Int         @id @default(autoincrement())
  name                              String
  slug                              String      @unique
  location                          String?
  region                            String?
  country                           String?
  difficulty                        String?
  duration_days                     Int?
  distance_km                       Decimal?    @db.Decimal(10, 2)
  max_altitude                      Int?
  altitude_gain                     Int?
  starting_point                    String?
  ending_point                      String?
  daily_trek_hours                  Int?
  temperature_range                 String?
  permits_required                  String? // "Yes"/"No"
  guide_mandatory                   Int?        @default(0) // 1 or 0
  fitness_level_required            Int?
  water_availability                Int?        @default(1) // 1 or 0
  food_availability                 Int?        @default(1) // 1 or 0
  mobile_network_availability       Int?        @default(1) // 1 or 0
  risk_level                        String?
  altitude_sickness_risk            String? // enum "high"/"low"
  nearest_medical_facility_distance Decimal?    @db.Decimal(10, 2)
  evacuation_possible               Int?        @default(1) // 1 or 0
  cost_min_usd                      Decimal?    @db.Decimal(10, 2)
  cost_max_usd                      Decimal?    @db.Decimal(10, 2)
  cultural_significance             String?     @db.Text
  group_size_min                    Int?
  group_size_max                    Int?
  popularity_score                  Int?        @default(0)
  is_active                         Int?        @default(1) // 1 or 0
  trek_images                       TrekImage[]

  @@map("treks")
}

model TrekImage {
  image_id   Int     @id @default(autoincrement())
  user_id    Int
  trek_id    Int
  url        String
  caption    String?
  is_cover   Int     @default(0) // 1 or 0
  sort_order Int?    @default(0)

  user User? @relation(fields: [user_id], references: [user_id])
  trek Trek? @relation(fields: [trek_id], references: [trek_id])

  @@map("trek_images")
}
